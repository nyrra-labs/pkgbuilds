# Maintainer: Anand Pant

pkgname=windsurf
pkgver=2.0.67
pkgrel=1
pkgdesc="The Windsurf Editor"
arch=('x86_64')
url="https://windsurf.com/"
license=('LicenseRef-Windsurf-Editor')
depends=(
  'alsa-lib'
  'dbus'
  'gcc-libs'
  'glib2'
  'glibc'
  'gtk3'
  'libnotify'
  'libsecret'
  'libx11'
  'libxkbfile'
  'libxss'
  'nss'
  'xdg-utils'
)
optdepends=(
  'org.freedesktop.secrets: Sync settings'
)
options=('!strip')
_source_url="https://windsurf-stable.codeiumdata.com/linux-x64/stable/08b5de9bae1728a5ad46386c9b8903192a125c51/Windsurf-linux-x64-2.0.67.tar.gz"
source=(
  "${pkgname}-${pkgver}.tar.gz::${_source_url}"
)
sha256sums=(
  'f2f10ef446096bc77c6d0513ea7ceb8a59398d5119a93f5b88a7c77a59727b67'
)

package() {
  install -dm755 "${pkgdir}/usr/share/windsurf"
  cp -a Windsurf/. "${pkgdir}/usr/share/windsurf/"

  install -dm755 "${pkgdir}/usr/bin"
  ln -s /usr/share/windsurf/bin/windsurf "${pkgdir}/usr/bin/windsurf"

  install -Dm644 "Windsurf/resources/app/resources/linux/code.png" \
    "${pkgdir}/usr/share/icons/hicolor/512x512/apps/${pkgname}.png"
  install -Dm644 "Windsurf/LICENSES.chromium.html" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSES.chromium.html"
  install -Dm644 "Windsurf/resources/app/LICENSE.txt" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE.txt"

  install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/${pkgname}.desktop" <<'EOF'
[Desktop Entry]
Name=Windsurf
Comment=The Windsurf Editor
Exec=windsurf %F
Icon=windsurf
Type=Application
Terminal=false
Categories=Development;IDE;TextEditor;
MimeType=text/plain;inode/directory;
StartupNotify=true
StartupWMClass=Windsurf
EOF
}
