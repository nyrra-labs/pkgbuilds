post_install() {
  cat <<'EOF'
==> nyrra-signals-bin: package-manager installs do not auto-open the guided setup.
==> Run the guided first-run flow from a real terminal:
    nyrra-signals setup
==> The TUI needs a TTY. If you launch it from a non-interactive runner, it cannot attach to /dev/tty.
EOF
}

post_upgrade() {
  post_install
}
